# Postgres. The API runs on the host, so it talks to the dockerized postgres
# service via its published port on localhost.
POSTGRES_USER=doc_share
POSTGRES_PASSWORD=doc_share
POSTGRES_DB=doc_share
DATABASE_URL=postgresql+psycopg://doc_share:doc_share@localhost:5432/doc_share

# MinIO (S3-compatible object storage). The API runs on the host, so both the
# API and the client's browser reach MinIO via the same published port.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=doc-share
MINIO_REGION=us-east-1

# Upload rules
MAX_UPLOAD_BYTES=26214400
ALLOWED_CONTENT_TYPES=application/pdf,image/png,image/jpeg,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

PRESIGNED_URL_EXPIRY_SECONDS=300

# Audit trail: if true, a failed audit write fails the request rather than
# serving an unlogged read (list/download). See README's Audit trail section.
AUDIT_FAIL_CLOSED=true
